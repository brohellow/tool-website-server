# Supabase 配置
# 请在 Supabase 控制台中获取以下配置信息

# Supabase 项目 URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名 API Key
VITE_SUPABASE_ANON_KEY=your-anon-key

# 如何获取这些配置：
# 1. 登录 https://supabase.com/dashboard
# 2. 创建或选择一个项目
# 3. 在左侧菜单中点击 "Settings" > "API"
# 4. 复制 "URL" 和 "anon public" 的值
